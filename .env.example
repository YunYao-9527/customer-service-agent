# =============================================================================
# 事务型智能客服 Agent - 环境变量配置
# =============================================================================

# 应用配置
APP_NAME=customer-service-agent
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/customer_service
DATABASE_ECHO=false

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# LLM 配置
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096

# Anthropic (可选)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229

# LLM Provider: openai | anthropic
LLM_PROVIDER=openai

# 向量数据库配置
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=customer_service_policies

# Embedding 模型
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Agent 配置
MAX_CONVERSATION_TURNS=20
MAX_TOOL_CALLS_PER_TURN=5
TOOL_CALL_TIMEOUT_SECONDS=30
ENABLE_GUARDRAILS=true

# 安全配置
ENABLE_INJECTION_DETECTION=true
SENSITIVE_FIELDS=phone,email,id_card,credit_card

# 评测配置
EVAL_MAX_CONCURRENT=5
EVAL_OUTPUT_DIR=./eval_results

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json
